/*
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; img-src 'self' data: https://ytimg.com/; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' https://gtm-analytics.netlify.app; connect-src 'self' https://gtm-analytics.netlify.app; media-src 'self'; frame-src 'self' https://www.youtube.com/ https://youtube-nocookie.com/; worker-src 'self' blob:; upgrade-insecure-requests; report-uri /.netlify/functions/csp-report

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/assets/docs/*
  Cache-Control: public, max-age=31536000, immutable

/assets/sprites/*
  Cache-Control: public, max-age=31536000, immutable